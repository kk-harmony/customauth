# Development: copy to .env or use appsettings.Development.json
# Production / Fly.io: set as environment variables (see PRODUCTION.md, FLY.md)

# PostgreSQL
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=customoauth;Username=postgres;Password=postgres

# Integration tests (optional)
# CUSTOMOAUTH_TEST_CONNECTION=Host=localhost;Port=5432;Database=customoauth;Username=postgres;Password=postgres

# OAuth server (Production: all required via env)
OAuthServer__Issuer=https://localhost:5001/
OAuthServer__CorsRootDomain=example.com
OAuthServer__AllowedOrigins__0=https://app.example.com
OAuthServer__RateLimitPerMinute=100

# Production signing (required when ASPNETCORE_ENVIRONMENT=Production)
# OAuthServer__SigningCertificatePath=/run/secrets/signing.pfx
# OAuthServer__SigningCertificatePassword=

# Database
# Database__AllowEnsureCreatedFallback=false

# Seed (Production: disabled after bootstrap)
Seed__Enabled=true
Seed__DemoUsers=true
Seed__DemoUserPassword=Password123!
Seed__ClientSecrets__m2m-client=your-m2m-secret
Seed__ClientSecrets__obo-client=your-obo-secret
Seed__ClientSecrets__introspection-client=your-introspection-secret
Seed__ClientSecrets__admin-client=your-admin-secret

# Security
Security__MaxFailedLoginAttempts=5
Security__LockoutMinutes=15
Security__LoginRateLimitPerMinute=20
Security__MinPasswordLength=12

# Serilog
Serilog__LogFilePath=logs/customoauth-.log
Serilog__MinimumLevel=Information

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:5001;http://localhost:5000
